<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="stock_move_line_view_tree" model="ir.ui.view">
            <field name="name">stock.move.line.tree</field>
            <field name="model">stock.move.line</field>
            <field name="inherit_id" ref="stock.view_move_line_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='qty_done']" position="after">
                    <field name="product_quantity_loss" readonly="1"/>
                </xpath>
            </field>
        </record>

        <record id="view_move_line_tree_inherit_historical_prices" model="ir.ui.view">
            <field name="name">stock.move.line.tree.inherit.prices</field>
            <field name="model">stock.move.line</field>
            <field name="inherit_id" ref="stock.view_move_line_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='product_id']" position="after">
                    <field name="historical_cost_price" readonly="1" optional="show" widget="monetary"/>
                    <field name="historical_sale_price" readonly="1" optional="show" widget="monetary"/>

                    <field name="historical_cgst_percent" readonly="1" optional="show" string="CGST %"/>
                    <field name="historical_sgst_percent" readonly="1" optional="show" string="SGST %"/>
                    <field name="historical_igst_percent" readonly="1" optional="show" string="IGST %"/>
                    <field name="historical_other_percent" readonly="1" optional="hide" string="Other %"/>
                </xpath>
            </field>
        </record>

    </data>
</odoo>